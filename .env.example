# ============================================================
# CONSULTORÍA HOST — Plantilla de variables de entorno
# ============================================================
# Copia este archivo como ".env" (sin .example) y rellena los
# valores reales. El .env NUNCA se sube al repositorio (.gitignore).
#
# Ubicación: raíz del proyecto, FUERA de public_html/
# bootstrap.php lo carga automáticamente al inicio de cada página.
# ============================================================

# --- Entorno ---
# 'production' en Hostinger, 'development' en local (Laragon)
APP_ENV=production

# ============================================================
# ENVÍO DE CORREO — SMTP de Hostinger
# ============================================================
# Datos de la cuenta contactoweb@consultoriahost.es
# Panel: hPanel → Correos → Cuentas de correo → Configurar
#
# El sitio ENVÍA los correos desde esta cuenta de Hostinger
# (mismo dominio = no marca como spam).
# ============================================================

MAIL_HOST=smtp.hostinger.com
MAIL_PORT=465
MAIL_ENCRYPTION=ssl
MAIL_USERNAME=contactoweb@consultoriahost.es
MAIL_PASSWORD=PON_AQUI_LA_CONTRASEÑA_DEL_CORREO

# Remitente que verá el destinatario (debe coincidir con MAIL_USERNAME)
MAIL_FROM_ADDRESS=contactoweb@consultoriahost.es
MAIL_FROM_NAME="Consultoría HOST"

# Destinatario de los mensajes del formulario de contacto
MAIL_TO_ADDRESS=contactoweb@consultoriahost.es
MAIL_TO_NAME="Consultoría HOST"

# Modo depuración SMTP (0 = silencioso en producción, 2 = verboso para depurar)
MAIL_DEBUG=0
