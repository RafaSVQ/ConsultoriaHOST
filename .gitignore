# ============================================================
# CONSULTORÍA HOST — .gitignore
# ============================================================

# Variables de entorno — NUNCA subir al repo
.env
.env.*
!.env.example

# Logs de PHP y servidor
*.log
error_log
php_error.log

# Archivos del sistema operativo
.DS_Store
Thumbs.db
desktop.ini

# Editores
.vscode/
.idea/
*.suo
*.user

# Caché y temporales
/tmp/
/cache/
*.tmp
*.swp
*.swo

# Dependencias (si se añaden en el futuro)
/vendor/
/node_modules/

# Archivos de backup generados durante el desarrollo
*.bak
*.orig

# Archivos de despliegue locales (no van al repo)
*.zip
CONSULTORISHOT-*.zip

# Carpeta de distribución — copia local lista para subir a Hostinger por FTP
/DIST/

# Documentos de trabajo (contratos, propuestas) — solo local, fuera del repo
/docs/

# Scripts de diagnóstico — solo para uso local, nunca a producción
test-smtp.php
test-*.php
link_checker.php
*_checker.php
